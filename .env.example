# ─── OpenAI ───────────────────────────────────────────────
# Your OpenAI API key (required)
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Model to use for summarization (optional, defaults to gpt-4o)
OPENAI_MODEL=gpt-4o

# Whisper model for transcription (optional, defaults to whisper-1)
WHISPER_MODEL=whisper-1

# ─── App Config ───────────────────────────────────────────
# Maximum upload size in MB (optional, defaults to 50)
MAX_UPLOAD_SIZE_MB=50

# Port for the dev server (optional, defaults to 3000)
PORT=3000
